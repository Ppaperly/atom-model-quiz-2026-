rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function isAdmin(){ return signedIn() && request.auth.uid == 'E2aywHHeSvbpcVW81AxcYIrubvE2'; }
    function sessionPath(sessionId){ return /databases/$(database)/documents/sessions/$(sessionId); }
    function submissionPath(submissionId){ return /databases/$(database)/documents/submissions/$(submissionId); }
    match /settings/app {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
    match /sessions/{sessionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid) || (signedIn() && resource.data.visibleToPeers == true);
      allow create: if signedIn() && !isAdmin() && request.resource.data.ownerUid == request.auth.uid && request.resource.data.visibleToPeers == true;
      allow update: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedAt']));
      allow delete: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid && resource.data.completedAt == null);
    }
    match /submissions/{submissionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid) || (signedIn() && resource.data.visibleToPeers == true);
      allow create: if signedIn() && !isAdmin() && request.resource.data.ownerUid == request.auth.uid && request.resource.data.visibleToPeers == true && request.resource.data.editAllowance == 0;
      allow update: if (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['editAllowance','visibleToPeers'])) || (signedIn() && resource.data.ownerUid == request.auth.uid && resource.data.editAllowance > 0 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageData','submissionType','editAllowance','modifiedAt']) && request.resource.data.editAllowance == resource.data.editAllowance - 1);
      allow delete: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid && get(sessionPath(resource.data.sessionId)).data.completedAt == null);
    }
    match /feedback/{feedbackId} {
      allow read: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid) || (signedIn() && get(submissionPath(resource.data.submissionId)).data.ownerUid == request.auth.uid) || (signedIn() && get(submissionPath(resource.data.submissionId)).data.visibleToPeers == true);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid && get(submissionPath(request.resource.data.submissionId)).data.visibleToPeers == true;
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && get(submissionPath(resource.data.submissionId)).data.ownerUid == request.auth.uid && get(sessionPath(get(submissionPath(resource.data.submissionId)).data.sessionId)).data.completedAt == null);
    }
  }
}
